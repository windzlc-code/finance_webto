# Bank Club production environment template.
# Copy to your hosting provider's environment settings. Do not commit real secrets.

# Required in production. Must be the public HTTPS origin without a trailing slash.
NEXT_PUBLIC_SITE_URL="https://your-domain.example"

# Required in production. Use a long random value, at least 32 characters.
AUTH_SECRET="replace-with-a-long-random-session-secret"

# Required in production. The admin login page only asks for this password.
# Do not use admin123 or BankClub2026! outside local development.
ADMIN_PASSWORD="replace-with-a-strong-admin-password"

# Optional but recommended. When set, new leads and retry actions post notification payloads here.
NOTIFY_WEBHOOK_URL="https://your-notification-endpoint.example/bank-club-leads"

# Optional test/smoke overrides. Normally leave unset.
# BASE_URL="https://your-domain.example"
# LAUNCH_SMOKE_EXPECTED_FAILS=""
