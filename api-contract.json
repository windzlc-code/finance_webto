    {
      "method": "GET",
      "path": "/api/admin/operations-tasks",
      "purpose": "運維任務隊列，彙整上線配置、SEO、合規、資料來源、個資、驗收、備份、Line OA 與發布待辦",
      "auth": "admin:super_admin|viewer|data_manager|compliance_reviewer",
      "response": ["format", "status_counts", "tasks", "next_review_cycle", "runbook", "generated_at"]
    },
    {
