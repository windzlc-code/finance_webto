{
  "version": "2026-06-27",
  "base_path": "/api",
  "security": {
    "public": ["GET products", "GET articles", "GET search", "POST leads", "POST events", "POST public feedback"],
    "admin": ["Bearer session token", "role based access control"],
    "rate_limit": {
      "POST /api/leads": "5 requests / 10 minutes / IP + device fingerprint",
      "POST /api/events": "60 requests / minute / IP",
      "POST /api/public-feedback": "10 requests / hour / IP + device fingerprint",
      "admin": "server session + CSRF protection"
    },
    "bot_protection": "Cloudflare Turnstile on POST /api/leads"
  },
  "endpoints": [
    {
      "method": "GET",
      "path": "/api/products",
      "purpose": "金融商品與公開資訊列表",
      "auth": "public",
      "query": ["type", "category", "audience", "region", "status", "keyword", "page"],
      "response": ["items", "page", "total"]
    },
    {
      "method": "GET",
      "path": "/api/products/:slug",
      "purpose": "金融商品與公開資訊詳情",
      "auth": "public",
      "response": ["id", "slug", "title", "source_url", "updated_at", "checks", "disclaimer"]
    },
    {
      "method": "GET",
      "path": "/api/institutions",
      "purpose": "公開機構資訊列表",
      "auth": "public",
      "query": ["type", "region", "keyword"],
      "response": ["items", "total"]
    },
    {
      "method": "GET",
      "path": "/api/articles",
      "purpose": "金融知識文章列表",
      "auth": "public",
      "query": ["category", "keyword", "status", "page"],
      "response": ["items", "page", "total"]
    },
    {
      "method": "GET",
      "path": "/api/articles/:slug",
      "purpose": "金融知識文章詳情",
      "auth": "public",
      "response": ["id", "slug", "title", "body", "source", "updated_at", "related_articles"]
    },
    {
      "method": "POST",
      "path": "/api/leads",
      "purpose": "提交免費財務健檢查詢",
      "auth": "public + turnstile",
      "request": ["display_name", "phone", "line_id", "region", "needs", "occupation_type", "income_type", "message", "consent_privacy", "consent_line", "consent_version", "source_url", "utm_source", "utm_medium", "utm_campaign", "utm_content", "utm_term", "device_id", "website", "cf_turnstile_response"],
      "validation": ["no national id", "no bank account", "no card number", "privacy consent required", "line consent optional and separate", "website honeypot must be empty", "turnstile token required when enabled", "rate limit by IP + device_id", "deduplicate same phone + needs within 24 hours"],
      "response": ["id", "status", "recommended_categories", "recommended_articles", "line_url", "disclaimer"]
    },
    {
      "method": "POST",
      "path": "/api/events",
      "purpose": "前台事件追蹤",
      "auth": "public",
      "request": ["name", "path", "url", "referrer", "payload", "at"],
      "response": ["accepted"]
    },
    {
      "method": "POST",
      "path": "/api/public-feedback",
      "purpose": "公眾資料回報、內容錯誤、合規疑慮與個資請求收件，建立去識別工單並分流",
      "auth": "public",
      "request": ["feedback_type", "page_url", "summary", "official_source_url", "source_updated_at", "reporter_contact_hash", "phone_last3", "consent_contact", "website"],
      "validation": ["no national id", "no bank account", "no card number", "no password", "reporter contact hash only", "website honeypot must be empty", "rate limit by IP + device_id"],
      "response": ["ticket_id", "status", "assigned_role", "related_task_type", "disclaimer"]
    },
    {
      "method": "GET",
      "path": "/api/search",
      "purpose": "全站搜尋",
      "auth": "public",
      "query": ["q", "type", "page"],
      "response": ["products", "articles", "categories"]
    },
    {
      "method": "POST",
      "path": "/api/admin/auth/login",
      "purpose": "Admin 伺服器登入，以 session 取代前端 MVP 明碼驗證",
      "auth": "public + csrf",
      "request": ["email", "password", "mfa_code", "csrf_token"],
      "validation": ["rate limit login attempts", "no password in audit logs", "issue httpOnly secure session cookie"],
      "response": ["admin_user", "session", "csrf_token", "expires_at", "audit_log"]
    },
    {
      "method": "GET",
      "path": "/api/admin/auth/session",
      "purpose": "取得目前 Admin session 與 RBAC 權限",
      "auth": "admin:super_admin|consultant|viewer|content_editor|data_manager|compliance_reviewer",
      "response": ["admin_user", "role", "permissions", "expires_at", "csrf_token"]
    },
    {
      "method": "GET",
      "path": "/api/admin/security-matrix",
      "purpose": "Admin 權限與安全矩陣，彙整角色權限、正式 session/CSRF/MFA/審計檢查與上線阻擋項",
      "auth": "admin:super_admin|viewer|data_manager|compliance_reviewer",
      "response": ["format", "roles", "checks", "blockers", "related_exports", "generated_at"]
    },
    {
      "method": "GET",
      "path": "/api/admin/security-headers-deployment-check",
      "purpose": "正式主機安全標頭、CSP、快取策略、security.txt、404/500 fallback 與平台套用證據核對包",
      "auth": "admin:super_admin|viewer|data_manager|compliance_reviewer",
      "response": ["format", "status", "source_files", "expected_headers", "csp_allowlist", "critical_urls", "host_notes", "verification_commands", "evidence_fields", "related_exports", "generated_at"]
    },
    {
      "method": "GET",
      "path": "/api/admin/auth-cutover-check",
      "purpose": "正式 Admin Auth 切換核對包，彙整 login/session/logout、cookie、CSRF、MFA、RBAC、Viewer 遮罩、audit_logs 與 MVP 驗證碼退場步驟",
      "auth": "admin:super_admin|viewer|data_manager|compliance_reviewer",
      "response": ["format", "status", "backend_mode", "api_base_url_configured", "endpoints", "schema_tables", "required_controls", "cutover_steps", "evidence_fields", "blockers", "related_exports", "generated_at"]
    },
    {
      "method": "POST",
      "path": "/api/admin/auth/logout",
      "purpose": "登出並撤銷目前 Admin session",
      "auth": "admin:super_admin|consultant|viewer|content_editor|data_manager|compliance_reviewer",
      "request": ["csrf_token"],
      "response": ["revoked", "audit_log"]
    },
    {
      "method": "GET",
      "path": "/api/admin/leads",
      "purpose": "潛客列表",
      "auth": "admin:super_admin|consultant|viewer",
      "query": ["status", "tag", "source", "keyword", "page"],
      "response": ["items", "page", "total"]
    },
    {
      "method": "GET",
      "path": "/api/admin/leads/:id",
      "purpose": "潛客詳情",
      "auth": "admin:super_admin|consultant|viewer",
      "response": ["lead", "events", "audit_logs"]
    },
    {
      "method": "PATCH",
      "path": "/api/admin/leads/:id/status",
      "purpose": "更新潛客狀態、備註、負責角色與下次跟進",
      "auth": "admin:super_admin|consultant",
      "request": ["status", "note", "assigned_to", "follow_up_priority", "next_follow_up_at", "contact_log"],
      "response": ["lead", "audit_log"]
    },
    {
      "method": "GET",
      "path": "/api/admin/leads/contact-logs",
      "purpose": "CRM 結構化聯繫紀錄，供正式 CRM 匯入與稽核",
      "auth": "admin:super_admin|consultant",
      "query": ["lead_id", "channel", "outcome", "handled_by", "period_start", "period_end", "page"],
      "response": ["format", "counts", "items", "page", "total", "generated_at"]
    },
    {
      "method": "GET",
      "path": "/api/admin/leads/follow-ups",
      "purpose": "CRM 待跟進隊列，供顧問查看未結案、新提交或已排程下次跟進的潛客",
      "auth": "admin:super_admin|consultant",
      "query": ["assigned_to", "priority", "due_before", "page"],
      "response": ["items", "counts", "page", "total"]
    },
    {
      "method": "GET",
      "path": "/api/admin/leads/dedupe-queue",
      "purpose": "CRM 重複線索處理隊列，依手機雜湊、需求與 24 小時窗口提出合併或關聯建議",
      "auth": "admin:super_admin|consultant",
      "query": ["status", "needs", "page"],
      "response": ["format", "dedupe_policy", "counts", "items", "related_exports", "generated_at"]
    },
    {
      "method": "GET",
      "path": "/api/admin/crm-api-persistence-package",
      "purpose": "CRM 正式 API 落庫驗收包，核對 lead_forms、lead_contact_logs、lead_dedupe_queues、audit_logs、RBAC、CSRF 與 Viewer 遮罩",
      "auth": "admin:super_admin|consultant",
      "response": ["format", "status", "backend_target", "local_context", "required_controls", "test_cases", "evidence_fields", "blockers", "related_exports", "generated_at"]
    },
    {
      "method": "GET",
      "path": "/api/admin/privacy-requests",
      "purpose": "個資查詢、更正與刪除請求隊列",
      "auth": "admin:super_admin|consultant|compliance_reviewer",
      "query": ["status", "type", "page"],
      "response": ["items", "page", "total"]
    },
    {
      "method": "PATCH",
      "path": "/api/admin/privacy-requests/:lead_id",
      "purpose": "標記個資請求已完成處理並寫入審計紀錄",
      "auth": "admin:super_admin|consultant|compliance_reviewer",
      "request": ["request_status", "note"],
      "response": ["lead", "audit_log"]
    },
    {
      "method": "GET",
      "path": "/api/admin/data-retention-purge-plan",
      "purpose": "資料保留、匿名化、到期刪除與 legal hold 月檢排程交接包",
      "auth": "admin:super_admin|data_manager|compliance_reviewer",
      "response": ["format", "policy", "retention_rules", "summary", "purge_candidates", "required_evidence_fields", "blockers", "related_exports", "generated_at"]
    },
    {
      "method": "GET",
      "path": "/api/admin/privacy-fulfillment-verification",
      "purpose": "個資查詢、更正與刪除正式履約驗收包，核對 privacy_request_tasks、lead_forms 遮罩/刪除、audit_logs、RBAC、CSRF 與下游匯出脫敏",
      "auth": "admin:super_admin|consultant|compliance_reviewer",
      "response": ["format", "status", "backend_target", "local_context", "required_controls", "test_cases", "evidence_fields", "blockers", "related_exports", "generated_at"]
    },
    {
      "method": "GET",
      "path": "/api/admin/line-segments",
      "purpose": "Line OA 分群同步隊列，僅列出已同意 Line 的潛客標籤",
      "auth": "admin:super_admin|consultant|content_editor",
      "query": ["tag", "source", "page"],
      "response": ["items", "page", "total"]
    },
    {
      "method": "GET",
      "path": "/api/admin/line-oa-setup",
      "purpose": "Line OA 設定交接包，包含歡迎語、圖文選單入口、quick reply、自動回覆原則、標籤與分群同步隊列",
      "auth": "admin:super_admin|consultant|content_editor",
      "response": ["format", "welcome_messages", "rich_menu", "quick_replies", "tags", "reply_principles", "segment_sync_queue", "compliance_boundaries", "records", "record_summary", "setup_steps", "generated_at"]
    },
    {
      "method": "GET",
      "path": "/api/admin/line-oa-handoff-check",
      "purpose": "正式 Line OA 導向驗收包，核對正式加友 URL、站內 CTA、免費財務健檢查詢成功承接、quick reply、退訂入口與外部留痕欄位",
      "auth": "admin:super_admin|consultant|content_editor",
      "response": ["format", "status", "line_oa_url", "official_url_ready", "source_files", "cta_routes", "quick_reply_checks", "handoff_steps", "evidence_fields", "compliance_boundaries", "records", "record_summary", "blockers", "related_exports", "generated_at"]
    },
    {
      "method": "GET",
      "path": "/api/admin/line-optout-complaints",
      "purpose": "Line 退訂、停止接收與投訴處理隊列，僅輸出去識別處理欄位、SLA、關鍵字、證據欄位與需升級合規/個資請求的待辦",
      "auth": "admin:super_admin|consultant|compliance_reviewer",
      "query": ["status", "type", "page"],
      "response": ["format", "summary", "intake_keywords", "sla", "handling_steps", "evidence_fields", "items", "related_exports", "generated_at"]
    },
    {
      "method": "GET",
      "path": "/api/admin/line-optout-api-verification",
      "purpose": "Line 退訂/投訴正式 API 驗收包，核對 line_optout_complaint_tasks、個資/法務升級、審計留痕、RBAC、CSRF 與去識別欄位回傳",
      "auth": "admin:super_admin|consultant|compliance_reviewer",
      "response": ["format", "status", "backend_target", "local_context", "required_controls", "test_cases", "evidence_fields", "blockers", "related_exports", "generated_at"]
    },
    {
      "method": "POST",
      "path": "/api/admin/products",
      "purpose": "新增資料庫條目",
      "auth": "admin:super_admin|data_manager",
      "request": ["title", "type", "category", "source_url", "updated_at", "summary", "checks"],
      "response": ["product", "audit_log"]
    },
    {
      "method": "PATCH",
      "path": "/api/admin/products/:id",
      "purpose": "更新資料庫條目與復核狀態",
      "auth": "admin:super_admin|data_manager",
      "request": ["title", "status", "source_url", "updated_at", "summary", "checks"],
      "response": ["product", "audit_log"]
    },
    {
      "method": "POST",
      "path": "/api/admin/articles",
      "purpose": "新增文章",
      "auth": "admin:super_admin|content_editor",
      "request": ["title", "slug", "category", "body", "seo_title", "seo_description", "status", "updated_at"],
      "response": ["article", "audit_log"]
    },
    {
      "method": "PATCH",
      "path": "/api/admin/articles/:id",
      "purpose": "更新文章與發布狀態",
      "auth": "admin:super_admin|content_editor",
      "request": ["title", "body", "status", "updated_at"],
      "response": ["article", "audit_log"]
    },
    {
      "method": "POST",
      "path": "/api/admin/articles/:id/review",
      "purpose": "提交文章審核動作，支援送審、核准發布、退回草稿與送回待審",
      "auth": "admin:super_admin|content_editor|compliance_reviewer",
      "request": ["status", "action", "note", "reviewer"],
      "response": ["article", "audit_log"]
    },
    {
      "method": "POST",
      "path": "/api/admin/compliance/review",
      "purpose": "提交合規審核紀錄，可附帶文案即時預檢結果",
      "auth": "admin:super_admin|compliance_reviewer",
      "request": ["type", "target", "result", "note", "reviewer", "scan_payload"],
      "response": ["review", "audit_log"]
    },
    {
      "method": "GET",
      "path": "/api/admin/audit-logs",
      "purpose": "審計日誌",
      "auth": "admin:super_admin|compliance_reviewer",
      "query": ["actor", "action", "target", "page"],
      "response": ["items", "page", "total"]
    },
    {
      "method": "GET",
      "path": "/api/admin/reports/retrospective",
      "purpose": "數據復盤報告，彙整事件漏斗、來源、熱門頁面、錯誤摘要與下週優化建議",
      "auth": "admin:super_admin|viewer|consultant|content_editor|data_manager|compliance_reviewer",
      "query": ["period_start", "period_end", "source"],
      "response": ["funnel", "engagement", "lead_summary", "top_paths", "quality", "next_actions", "generated_at"]
    },
    {
      "method": "GET",
      "path": "/api/admin/reports/tracking-consent-audit",
      "purpose": "外部追蹤同意檢查包，核對 GA4、Meta Pixel、Server Event 是否在 analytics 同意後才轉發",
      "auth": "admin:super_admin|viewer|data_manager|compliance_reviewer",
      "response": ["format", "consent_status", "consent_record", "external_destinations", "event_counts", "policy", "blockers", "related_exports", "generated_at"]
    },
    {
      "method": "GET",
      "path": "/api/admin/reports/utm-attribution",
      "purpose": "UTM 與投流歸因報表，按 source/medium/campaign/content/term 聚合 CTA、表單、Line 點擊與線索轉換",
      "auth": "admin:super_admin|viewer|consultant|content_editor|data_manager|compliance_reviewer",
      "query": ["period_start", "period_end", "utm_source", "utm_campaign"],
      "response": ["summary", "campaigns", "next_actions", "generated_at"]
    },
    {
      "method": "GET",
      "path": "/api/admin/reports/server-event-replay",
      "purpose": "Server Event 正式接入前後的去識別事件重放隊列，用於核對 GA4、Meta Pixel 與伺服器事件端點",
      "auth": "admin:super_admin|viewer|consultant|content_editor|data_manager|compliance_reviewer",
      "response": ["format", "destinations", "counts", "event_name_counts", "missing_required_event_names", "queue", "replay_steps", "generated_at"]
    },
    {
      "method": "GET",
      "path": "/api/admin/reports/monitoring-receipt-checklist",
      "purpose": "GA4、Meta Pixel、Server Event 與 Sentry 正式收件驗收清單",
      "auth": "admin:super_admin|viewer|consultant|content_editor|data_manager|compliance_reviewer",
      "response": ["format", "destinations", "summary", "required_events", "missing_required_events", "receipt_checks", "blockers", "related_exports", "generated_at"]
    },
    {
      "method": "GET",
      "path": "/api/admin/reports/sentry-error-verification",
      "purpose": "Sentry 前台與後端錯誤收件驗收包，核對測試錯誤、敏感欄位遮罩、environment/release 標籤、source map 與事故留痕",
      "auth": "admin:super_admin|viewer|data_manager|compliance_reviewer",
      "response": ["format", "status", "destinations", "required_controls", "test_cases", "recent_local_errors", "evidence_fields", "blockers", "related_exports", "generated_at"]
    },
    {
      "method": "GET",
      "path": "/api/admin/reports/analytics-debug-verification",
      "purpose": "GA4 DebugView 與 Meta Events Manager 驗證包，彙整本機事件映射、追蹤同意、必要事件、Debug 步驟與外部證據欄位",
      "auth": "admin:super_admin|viewer|consultant|content_editor|data_manager|compliance_reviewer",
      "response": ["format", "status", "destinations", "event_mappings", "debug_steps", "evidence_fields", "blockers", "related_exports", "generated_at"]
    },
    {
      "method": "GET",
      "path": "/api/admin/ad-campaigns",
